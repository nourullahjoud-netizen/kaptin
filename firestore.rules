rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Predictions rules
    match /predictions/{predictionId} {
      allow read: if true; // Public predictions are viewable by anyone
      allow create, update: if isValidId(predictionId) && (
        (isSignedIn() && request.resource.data.userId == request.auth.uid) ||
        (!isSignedIn() && request.resource.data.userId == predictionId)
      ) && (
        request.resource.data.userName is string &&
        request.resource.data.userName.size() <= 40
      );
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || (!isSignedIn() && resource.data.userId == predictionId);
    }

    // Rooms rules
    match /rooms/{roomId} {
      allow read: if true; // Room catalog is read to enter
      allow create: if isValidId(roomId) && (
        (isSignedIn() && request.resource.data.createdBy == request.auth.uid) ||
        (!isSignedIn() && request.resource.data.createdBy is string && request.resource.data.createdBy != "")
      ) && (
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 50
      );
      allow update: if (
        // Allow updating members array when someone joins
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberCount'])
      );
      allow delete: if (isSignedIn() && resource.data.createdBy == request.auth.uid) || (!isSignedIn() && resource.data.createdBy == request.resource.data.createdBy);
    }
  }
}
